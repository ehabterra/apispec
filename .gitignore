# Binaries and build output
main
*.exe
*.out
*.test

# Go modules
vendor/
# …but NOT the embedded UI's vendored bundle — it's a required runtime asset
# (the Preact/htm module) that must be committed and go:embed'd, or the UI 404s.
!cmd/apispecui/assets/vendor/
!cmd/apispecui/assets/vendor/**

# Dependency directories (remove the comment below if you use Go modules)
Gopkg.lock
Gopkg.toml

# IDE/editor files
.vscode/
.idea/
*.swp
*.swo
*.bak
.DS_Store

# APISpec generated files
metadata.yaml
# …except committed test fixtures the test suite loads (must exist in CI).
!testdata/echo/metadata.yaml
!testdata/echo_handler_factory/metadata.yaml
metadata-string-pool.yaml
metadata-packages.yaml
metadata-call-graph.yaml
diagram.html
used-config.yaml
openapi*.yaml

# Local, machine-specific external project list for scripts/compare-spec.sh
scripts/compare-spec.paths

# Test output
*.log

# OS files
Thumbs.db

openapi.json
output.txt
test_output.txt
coverage.txt
coverage.html

/apispec
/apidiag

# Test temporary directories
testdata/temp/
cmd/apispec/testdata/temp/

# Profiling output
profiles*/

# Playground optimized
playground*.go

